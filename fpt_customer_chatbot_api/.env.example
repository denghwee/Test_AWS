PROJECT_NAME="FPT Customer Chatbot API"
VERSION="1.0.0"
API_V1_STR="/api/v1"
SECRET_KEY="change-this-secret"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Local development fallback
SQLALCHEMY_DATABASE_URL="sqlite:///./fpt_chatbot.db"

# AWS RDS PostgreSQL production/development database.
# When DATABASE_URL is set, the app uses it instead of SQLALCHEMY_DATABASE_URL.
# Replace <password> and <rds-endpoint> with your RDS values.
DATABASE_URL="postgresql+psycopg2://postgres:<password>@fastapi-db.ctg640i20grg.ap-southeast-2.rds.amazonaws.com:5432/fastapi_prod"
DATABASE_SSLMODE="verify-full"
DATABASE_SSLROOTCERT="./global-bundle.pem"

OPENAI_API_KEY=""
TAVILY_API_KEY=""

AWS_REGION="ap-southeast-1"
S3_BUCKET_NAME="fastapi-app-files-<your-id>"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_SESSION_TOKEN=""
